# MiroFishTrader — 환경변수 템플릿
# cp .env.example .env 후 실제 값 입력

# MiroFish (로컬 Docker)
MIROFISH_BASE_URL=http://localhost:5001
MIROFISH_TIMEOUT=300

# LLM — litellm 프록시 (Claude → OpenAI 호환)
LLM_API_KEY=your_anthropic_api_key
LLM_BASE_URL=http://localhost:8001  # litellm proxy
LLM_MODEL=claude-sonnet-4-6

# Zep Cloud (에이전트 장기기억)
ZEP_API_KEY=your_zep_api_key

# Reddit API (asyncpraw)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=MiroFishTrader/1.0 by your_reddit_username

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SLACK_CHANNEL=#investment-ideas

# Anthropic (직접 호출용 — seed 텍스트 생성)
ANTHROPIC_API_KEY=your_anthropic_api_key
